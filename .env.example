# Прод-переменные для docker compose (frontend собирается с ними).
# Скопировать в .env на сервере и подставить реальные значения.

# Адрес backend, куда фронт шлёт запросы. Фаза 1: http://<IP_сервера>:3000
VITE_API_URL=http://localhost:3000

# Supabase (Cloud): URL проекта и публичный anon-ключ.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
